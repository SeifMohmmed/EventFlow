{
  "ConnectionStrings": {
    "Database": "Host=eventflow.database;Port=5432;Database=eventflow;Username=postgres;Password=postgres;Include Error Detail=true",
    "Cache": "eventflow.redis:6379",
    "Queue": "amqp://eventFlow.queue:5672"
  },
  "Authentication": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [ "http://eventFlow.identity:8080/realms/eventFlow", "http://localhost:18080/realms/eventFlow" ]
    },
    "MetadataAddress": "http://eventFlow.identity:8080/realms/eventFlow/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "HealthUrl": "http://eventFlow.identity:8080/health/"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "EventFlow.Modules.Attendance.Infrastructure.Outbox": "Warning",
        "EventFlow.Modules.Attendance.Infrastructure.Inbox": "Warning",
        "EventFlow.Modules.Events.Infrastructure.Outbox": "Warning",
        "EventFlow.Modules.Events.Infrastructure.Inbox": "Warning",
        "EventFlow.Modules.Ticketing.Infrastructure.Outbox": "Warning",
        "EventFlow.Modules.Ticketing.Infrastructure.Inbox": "Warning",
        "EventFlow.Modules.Users.Infrastructure.Outbox": "Warning",
        "EventFlow.Modules.Users.Infrastructure.Inbox": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://eventflow.seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "EventFlow.Api"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://eventFlow.jaeger:4317"
}
