{
  "Authentication": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [
        "http://eventFlow.identity:8080/realms/eventFlow",
        "http://localhost:18080/realms/eventFlow"
      ]
    },
    "MetadataAddress": "http://eventFlow.identity:8080/realms/eventFlow/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://eventflow.seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "EventFlow.Gateway"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://eventFlow.jaeger:4317",
  "ReverseProxy": {
    "Routes": {
      "eventFlow-route1": {
        "ClusterId": "eventFlow-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "eventFlow-route2": {
        "ClusterId": "eventFlow-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "users/register"
        }
      },
      "eventFlow-ticketing-route1": {
        "ClusterId": "eventflow-ticketing-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "orders/{**catch-all}"
          }
        ]
      },
      "eventFlow-ticketing-route2": {
        "ClusterId": "eventflow-ticketing-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "carts/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "carts/{**catch-all}"
          }
        ]
      },
      "eventFlow-ticketing-route3": {
        "ClusterId": "eventflow-ticketing-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "tickets/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "tickets/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "eventFlow-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://eventflow.api:8080"
          }
        }
      },
      "eventflow-ticketing-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://eventflow.ticketing.api:8080"
          }
        }
      }
    }
  }
}